{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "restaurant-route": {
          "ClusterId": "restaurant-cluster",
          "Match": {
            "Path": "/api/restaurants/{**catch-all}"
          }
        },
        "order-route": {
          "ClusterId": "order-cluster",
          "Match": {
            "Path": "/api/orders/{**catch-all}"
          }
        },
        "Metadata": {
          "RequireAuth": "true"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-server": {
            "Address": "http://localhost:5149"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-service": {
            "Address": "http://localhost:7008"
          }
        }
      },
      "restaurant-cluster": {
        "Destinations": {
          "restaurant-service": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-service": {
            "Address": "http://localhost:5004"
          }
        }
      }
    }
  }
  }