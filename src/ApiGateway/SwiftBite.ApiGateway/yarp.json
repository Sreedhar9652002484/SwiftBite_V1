{
  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },

      "openiddict-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/connect/{**catch-all}" }
      },

      "user-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },

      "restaurant-route": {
        "ClusterId": "restaurant-cluster",
        "Match": { "Path": "/api/restaurants/{**catch-all}" }
      },

      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },

      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/payments/{**catch-all}" }
      },

      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "delivery-route": {
        "ClusterId": "delivery-cluster",
        "Match": {
          "Path": "/api/delivery/{**catch-all}"
        }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/{**catch-all}" }
      }

    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-server": { "Address": "http://localhost:5149" }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-service": { "Address": "http://localhost:5001" }
        }
      },
      "restaurant-cluster": {
        "Destinations": {
          "restaurant-service": { "Address": "http://localhost:5003" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-service": { "Address": "http://localhost:5004" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-service": { "Address": "http://localhost:5005" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": { "Address": "http://localhost:5006" }
        }
      },
      "delivery-cluster": {
        "Destinations": {
          "delivery-service": {
            "Address": "http://localhost:5007"
          }
        }
      }
      }
    }
}